class ModulesTest < Test {
  def test_include_instance_method {
    module Greet {
      def hi { "hi" }
    }
    class Person {
      include Greet
    }
    assert_equal("hi", Person.new.hi)
  }

  def test_super_traverses_module_then_superclass {
    module M {
      def greet { "m:" + super.greet }
    }
    class Base {
      def greet { "base" }
    }
    class Child < Base {
      include M
      def greet { "c:" + super.greet }
    }
    assert_equal("c:m:base", Child.new.greet)
  }

  def test_is_a_included_module {
    module Trackable { }
    class C {
      include Trackable
    }
    assert(C.new.is_a?(Trackable))
  }

  def test_nested_include_resolves_lexically {
    class Outer {
      module Inner {
        def x { 1 }
      }
      class Sub {
        include Inner
      }
    }
    assert_equal(1, Outer.Sub.new.x)
  }

  def test_module_new_raises {
    module MEmpty { }
    assert_raises {
      MEmpty.new
    }
  }
}