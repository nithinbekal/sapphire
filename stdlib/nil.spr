# Nil is the type of the singleton nil value.
# It participates in nil checks and string conversion.
#
class Nil {
  # Returns true. nil is the only value that answers true to nil?.
  #
  #   nil.nil?()   # true
  #
  def nil?() {
    true
  }

  # Returns the string "nil" for display.
  #
  #   nil.to_s()   # "nil"
  #
  def to_s() {
    "nil"
  }
}
