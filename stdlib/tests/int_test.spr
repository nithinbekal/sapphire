class IntTest < Test {
  def test_even_true {
    assert(4.even?())
  }

  def test_even_false {
    assert(!3.even?())
  }

  def test_odd_true {
    assert(3.odd?())
  }

  def test_odd_false {
    assert(!4.odd?())
  }

  def test_max_returns_larger {
    assert_equal(10, 5.max(10))
  }

  def test_max_is_larger {
    assert_equal(10, 10.max(5))
  }

  def test_min_returns_smaller {
    assert_equal(5, 5.min(10))
  }

  def test_min_other_is_smaller {
    assert_equal(5, 10.min(5))
  }
}
