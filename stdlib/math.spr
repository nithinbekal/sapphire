class Math {
  PI = 3.141592653589793
  E = 2.718281828459045

  self {
    def tan(x) { self.sin(x) / self.cos(x) }

    def acos(x) { self.PI / 2 - self.asin(x) }

    def atan2(y, x) {
      if x > 0 {
        self.atan(y / x)
      } elsif x < 0 && y >= 0 {
        self.atan(y / x) + self.PI
      } elsif x < 0 {
        self.atan(y / x) - self.PI
      } elsif y > 0 {
        self.PI / 2
      } elsif y < 0 {
        0 - self.PI / 2
      } else {
        0
      }
    }
  }
}
