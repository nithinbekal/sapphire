# hello.spr — variables, arithmetic, string interpolation

name = "Sapphire"
version = 1

print "Hello from #{name} v#{version}!"

x = 10
y = 3
print "#{x} + #{y} = #{x + y}"
print "#{x} - #{y} = #{x - y}"
print "#{x} * #{y} = #{x * y}"
print "#{x} / #{y} = #{x / y}"
print "#{x} % #{y} = #{x % y}"

pi = 3.14159
print "pi is approximately #{pi}"
print "pi rounded down: #{pi.to_i}"
